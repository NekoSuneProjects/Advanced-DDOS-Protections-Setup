#!/usr/bin/env bash
# ddos-protect — master on/off/status switch for the toolkit (Linux + macOS).
# Installed to /usr/local/bin/ddos-protect by install.sh.
#
# Usage:
#   ddos-protect on        # enable firewall + fail2ban + watcher
#   ddos-protect off       # disable everything but keep configs (fast re-enable)
#   ddos-protect status    # show current state of each component
#   ddos-protect restart   # off then on
#
# Persistence: this is a runtime toggle. After reboot the system comes back ON
# (the install state is the default). For permanent removal use uninstall.sh.
set -euo pipefail

GREEN=$'\033[32m'; RED=$'\033[31m'; YELLOW=$'\033[33m'; DIM=$'\033[2m'; RESET=$'\033[0m'

is_root() { [[ $EUID -eq 0 ]]; }
need_root() { is_root || { echo "Run as root: sudo ddos-protect $*" >&2; exit 1; }; }

os() {
    case "$(uname -s)" in
        Linux*)  echo linux ;;
        Darwin*) echo macos ;;
        *)       echo unknown ;;
    esac
}

# ---------- Firewall ----------
fw_on_linux() {
    if command -v nft >/dev/null 2>&1 && [[ -r /etc/ddos-protect/ddos.nft ]] && \
       ! nft list table inet ddos_protect >/dev/null 2>&1; then
        nft -f /etc/ddos-protect/ddos.nft
    fi
    if command -v iptables >/dev/null 2>&1; then
        if iptables -L DDOS_PROTECT -n >/dev/null 2>&1; then
            iptables -C INPUT -j DDOS_PROTECT 2>/dev/null || iptables -I INPUT 1 -j DDOS_PROTECT
        fi
    fi
}
fw_off_linux() {
    command -v iptables >/dev/null 2>&1 && \
        iptables -D INPUT -j DDOS_PROTECT 2>/dev/null || true
    if command -v nft >/dev/null 2>&1 && nft list table inet ddos_protect >/dev/null 2>&1; then
        nft delete table inet ddos_protect 2>/dev/null || true
    fi
}
fw_status_linux() {
    local on=0
    command -v iptables >/dev/null 2>&1 && iptables -C INPUT -j DDOS_PROTECT 2>/dev/null && on=1
    command -v nft >/dev/null 2>&1 && nft list table inet ddos_protect >/dev/null 2>&1 && on=1
    (( on )) && echo on || echo off
}

fw_on_macos()  { [[ -f /etc/pf.anchors/ddos-protect ]] && pfctl -ef /etc/pf.conf 2>/dev/null || true; }
fw_off_macos() { pfctl -d 2>/dev/null || true; }
fw_status_macos() {
    pfctl -s info 2>/dev/null | grep -q 'Status: Enabled' && echo on || echo off
}

# ---------- fail2ban ----------
svc_on()  {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl start "$1" 2>/dev/null || true
    elif command -v brew >/dev/null 2>&1; then
        sudo -u "${SUDO_USER:-$USER}" brew services start "$1" 2>/dev/null || true
    fi
}
svc_off() {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl stop "$1" 2>/dev/null || true
    elif command -v brew >/dev/null 2>&1; then
        sudo -u "${SUDO_USER:-$USER}" brew services stop "$1" 2>/dev/null || true
    fi
}
svc_status() {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl is-active --quiet "$1" && echo on || echo off
    elif command -v brew >/dev/null 2>&1; then
        sudo -u "${SUDO_USER:-$USER}" brew services list 2>/dev/null | awk -v s="$1" '$1==s {print $2}' \
            | grep -qi started && echo on || echo off
    else
        echo unknown
    fi
}

# ---------- Watcher ----------
watcher_on_linux()  { svc_on  ddos-watcher.timer; }
watcher_off_linux() { svc_off ddos-watcher.timer; }
watcher_status_linux() { svc_status ddos-watcher.timer; }

watcher_on_macos()  { launchctl load -w /Library/LaunchDaemons/com.ddosprotect.watcher.plist 2>/dev/null || true; }
watcher_off_macos() { launchctl unload /Library/LaunchDaemons/com.ddosprotect.watcher.plist 2>/dev/null || true; }
watcher_status_macos() {
    launchctl list 2>/dev/null | awk '{print $3}' | grep -qx com.ddosprotect.watcher && echo on || echo off
}

# ---------- dispatch ----------
cmd_on()  {
    need_root on
    case "$(os)" in
        linux) fw_on_linux;  svc_on  fail2ban; watcher_on_linux ;;
        macos) fw_on_macos;  svc_on  fail2ban; watcher_on_macos ;;
        *) echo "Unsupported OS" >&2; exit 1 ;;
    esac
    printf '%sddos-protect: ON%s\n' "$GREEN" "$RESET"
    cmd_status
}

cmd_off() {
    need_root off
    case "$(os)" in
        linux) fw_off_linux; svc_off fail2ban; watcher_off_linux ;;
        macos) fw_off_macos; svc_off fail2ban; watcher_off_macos ;;
        *) echo "Unsupported OS" >&2; exit 1 ;;
    esac
    printf '%sddos-protect: OFF%s\n' "$YELLOW" "$RESET"
    printf '%s(configs untouched — run "ddos-protect on" to re-enable, or uninstall.sh to remove)%s\n' \
        "$DIM" "$RESET"
}

cmd_status() {
    local fw f2b w
    case "$(os)" in
        linux) fw="$(fw_status_linux)"; w="$(watcher_status_linux)" ;;
        macos) fw="$(fw_status_macos)"; w="$(watcher_status_macos)" ;;
    esac
    f2b="$(svc_status fail2ban)"
    paint() { [[ "$1" == on ]] && echo "${GREEN}on${RESET}" || echo "${RED}off${RESET}"; }
    printf '  Firewall:   %s\n' "$(paint "$fw")"
    printf '  fail2ban:   %s\n' "$(paint "$f2b")"
    printf '  Watcher:    %s\n' "$(paint "$w")"
}

cmd_help() {
    cat <<USE
Usage: ddos-protect <command>

  on             Enable firewall hook, start fail2ban, start watcher
  off            Disable everything (configs stay in place)
  status         Show on/off state of each component
  restart        off then on
  bans           List banned IPs grouped by jail (and lifetime counts)
  bans --top     Show top jails by current ban count
  bans --geo     Add GeoIP/ISP per banned IP (uses ip-api.com free tier)
  stats          Detailed: chain drop counters + watcher sample + top peers
  ban <ip> [j]   Add manual ban (default jail: sshd)
  unban <ip> [j] Remove ban (jail name or "all")

Components controlled:
  • Edge firewall (iptables chain / nftables table / pf state)
  • fail2ban service
  • ddos-watcher (systemd timer / launchd daemon)

For Cloudflare "Under Attack" mode:    ddos-cf on / off
For ad-hoc notifications:              ddos-notify "title" "msg"
For permanent removal:                 sudo /opt/ddos-protect/uninstall.sh
USE
}

# ---------- Banned IPs ----------
cmd_bans() {
    local geo=0 top=0 a
    for a in "$@"; do
        case "$a" in
            --geo) geo=1 ;;
            --top) top=1 ;;
        esac
    done

    if ! command -v fail2ban-client >/dev/null 2>&1; then
        echo "${YELLOW}fail2ban not installed — no jail bans to show${RESET}"
    else
        local jails total=0 currently=0
        jails=$(fail2ban-client status 2>/dev/null \
            | sed -n 's/.*Jail list:[[:space:]]*//p' | tr ',' ' ')
        if [[ -z "$jails" ]]; then
            echo "${YELLOW}fail2ban running but no jails active${RESET}"
        else
            printf '%s%-22s %-9s %-9s %s%s\n' "$DIM" "Jail" "Active" "Lifetime" "Currently banned IPs" "$RESET"
            local -a all_ips=()
            local -a all_jails=()
            for j in $jails; do
                local s cur tot ips
                s=$(fail2ban-client status "$j" 2>/dev/null) || continue
                cur=$(awk -F: '/Currently banned/  {gsub(/^ +| +$/,"",$2); print $2}' <<<"$s")
                tot=$(awk -F: '/Total banned/      {gsub(/^ +| +$/,"",$2); print $2}' <<<"$s")
                ips=$(awk -F: '/Banned IP list/    {sub(/^[^:]+:[[:space:]]*/,""); print}' <<<"$s")
                cur="${cur:-0}"; tot="${tot:-0}"
                currently=$((currently + cur))
                total=$((total + tot))
                printf '%-22s %-9d %-9d %s\n' "$j" "$cur" "$tot" "${ips:-—}"
                if (( cur > 0 )); then
                    for ip in $ips; do
                        all_ips+=( "$ip" )
                        all_jails+=( "$j" )
                    done
                fi
            done
            echo
            printf 'Total currently banned: %s%d%s   Lifetime bans: %s%d%s\n' \
                "$GREEN" "$currently" "$RESET" "$DIM" "$total" "$RESET"

            if (( top )) && (( currently > 0 )); then
                echo
                echo "${DIM}Top jails by current bans:${RESET}"
                printf '%s\n' "${all_jails[@]}" | sort | uniq -c | sort -rn | head -10 \
                    | awk '{printf "  %-22s %s\n", $2, $1}'
            fi

            if (( geo )) && (( currently > 0 )); then
                if ! command -v curl >/dev/null 2>&1; then
                    echo "${YELLOW}--geo needs curl${RESET}"
                else
                    echo
                    echo "${DIM}GeoIP (ip-api.com, free tier):${RESET}"
                    printf '%-18s %-22s %-3s %-25s %s\n' "IP" "Jail" "CC" "ISP" "City"
                    local i
                    for i in "${!all_ips[@]}"; do
                        (( i >= 25 )) && { echo "  …(truncated)"; break; }
                        local ip="${all_ips[$i]}" j="${all_jails[$i]}"
                        local r
                        r=$(curl -sS -m 4 "http://ip-api.com/json/${ip}?fields=country,countryCode,isp,city" 2>/dev/null) || r=""
                        local cc isp city
                        cc=$(sed -n 's/.*"countryCode":"\([^"]*\)".*/\1/p' <<<"$r")
                        isp=$(sed -n 's/.*"isp":"\([^"]*\)".*/\1/p' <<<"$r")
                        city=$(sed -n 's/.*"city":"\([^"]*\)".*/\1/p' <<<"$r")
                        printf '%-18s %-22s %-3s %-25s %s\n' "$ip" "$j" "${cc:-?}" "${isp:-?}" "${city:-?}"
                        sleep 0.3   # ip-api free tier: 45 req/min
                    done
                fi
            fi
        fi
    fi

    # Firewall drop counts.
    if command -v iptables >/dev/null 2>&1 && iptables -L DDOS_PROTECT -n >/dev/null 2>&1; then
        echo
        echo "${DIM}Firewall drop counters (DDOS_PROTECT chain):${RESET}"
        iptables -L DDOS_PROTECT -n -v 2>/dev/null \
            | awk 'NR<=2 || $1+0>0 {print "  "$0}'
    fi
    if command -v pfctl >/dev/null 2>&1 && pfctl -s rules 2>/dev/null | grep -q ddos-protect; then
        echo
        echo "${DIM}pf rule hit counters:${RESET}"
        pfctl -s rules -v 2>/dev/null | awk '/ddos-protect/,/^[^ ]/' | head -40
    fi
}

# ---------- Detailed stats ----------
cmd_stats() {
    cmd_status
    echo
    if [[ -r /var/lib/ddos-protect/last-sample.txt ]]; then
        echo "${DIM}Last watcher sample:${RESET}"
        sed 's/^/  /' /var/lib/ddos-protect/last-sample.txt
    fi
    echo
    if command -v iptables >/dev/null 2>&1 && iptables -L DDOS_PROTECT -n >/dev/null 2>&1; then
        echo "${DIM}DDOS_PROTECT chain (top 15 drop rules by packet count):${RESET}"
        iptables -L DDOS_PROTECT -n -v 2>/dev/null \
            | awk 'NR>2' | sort -rnk1 | head -15 | sed 's/^/  /'
    fi
    echo
    if command -v ss >/dev/null 2>&1; then
        echo "${DIM}Top 10 foreign IPs by established connections:${RESET}"
        ss -ntH state established 2>/dev/null | awk '{print $5}' \
            | sed 's/:[0-9]*$//' | sort | uniq -c | sort -rn | head -10 \
            | awk '{printf "  %-18s %s\n", $2, $1}'
    fi
}

# ---------- ban / unban (wrap fail2ban-client) ----------
cmd_ban() {
    [[ -n "${1:-}" ]] || { echo "usage: ddos-protect ban <ip> [jail]" >&2; exit 1; }
    local ip="$1" jail="${2:-sshd}"
    need_root ban
    fail2ban-client set "$jail" banip "$ip"
}
cmd_unban() {
    [[ -n "${1:-}" ]] || { echo "usage: ddos-protect unban <ip> [jail|all]" >&2; exit 1; }
    local ip="$1" jail="${2:-all}"
    need_root unban
    if [[ "$jail" == "all" ]]; then
        fail2ban-client unban "$ip"
    else
        fail2ban-client set "$jail" unbanip "$ip"
    fi
}

case "${1:-help}" in
    on)       cmd_on ;;
    off)      cmd_off ;;
    status|"")
              printf '%sddos-protect status:%s\n' "$DIM" "$RESET"
              cmd_status ;;
    restart)  cmd_off; cmd_on ;;
    bans)     shift; cmd_bans "$@" ;;
    stats)    cmd_stats ;;
    ban)      shift; cmd_ban   "$@" ;;
    unban)    shift; cmd_unban "$@" ;;
    help|-h|--help) cmd_help ;;
    *) echo "unknown command: $1"; cmd_help; exit 2 ;;
esac
